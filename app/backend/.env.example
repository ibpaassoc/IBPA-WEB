# Database
DATABASE_URL="postgresql://user:password@neon-db-url/dbname"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Optional: support separate secrets per mode or secret rotation
STRIPE_WEBHOOK_SECRET_TEST="whsec_..."
STRIPE_WEBHOOK_SECRET_LIVE="whsec_..."
STRIPE_WEBHOOK_SECRETS="whsec_old,whsec_new"
STRIPE_PRICE_SPECIALIST="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_TRAINER="price_..."
STRIPE_PRICE_BUSINESS="price_..."
STRIPE_PRICE_BRAND="price_..."
STRIPE_PRICE_SPONSOR_ASSOCIATE="price_..."
STRIPE_PRICE_SPONSOR_COMMUNITY="price_..."
STRIPE_PRICE_SPONSOR_PREMIER="price_..."

# Clerk
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
ADMIN_INTERNAL_KEY="your_admin_internal_key"
RECAPTCHA_SECRET_KEY="your_recaptcha_secret_key"

# Resend
RESEND_API_KEY="re_..."
# Development defaults to dry-run logging unless this is explicitly enabled.
EMAIL_SENDING_ENABLED=false
NO_REPLY_EMAIL="no-reply@yourdomain.com"
SUPPORT_EMAIL="support@yourdomain.com"
APPLICATIONS_EMAIL="applications@yourdomain.com"
PAYMENTS_EMAIL="payments@yourdomain.com"
ADMIN_EMAIL="admin@yourdomain.com"

# App
PORT=3003
FRONTEND_URL="https://yourdomain.com"
DASHBOARD_URL="https://yourdomain.com"
BACKEND_URL="https://your-backend-origin.example.com"
ALLOWED_ORIGINS="https://yourdomain.com"
